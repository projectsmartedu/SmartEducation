{
  "name": "smart-education-ml-service",
  "version": "2.0.0",
  "description": "ML Model Microservice for Risk Prediction and Revision Planning",
  "main": "server.js",
  "scripts": {
    "prestart": "pip install -r requirements.txt || true",
    "build": "bash build.sh || pip install -r requirements.txt",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "python3 scripts/test_model.py",
    "train": "python3 scripts/train_models.py"
  },
  "keywords": [
    "ml",
    "xgboost",
    "risk-prediction",
    "education",
    "microservice"
  ],
  "author": "Smart Education",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  },
  "engines": {
    "node": ">=14.0.0",
    "python": ">=3.8"
  }
}
